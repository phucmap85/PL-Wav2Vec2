{
  "train_csv": "metadata/train_phones.csv",
  "eval_csv": "metadata/eval_phones.csv",
  "audio_root": ".",
  "vocab_file": "vocab.json",
  "base_model": "nguyenvulebinh/wav2vec2-base-vietnamese-250h",
  "output_dir": "outputs/wav2vec2-250h-pitch",
  "validation_ratio": null,
  "seed": 42,
  "sampling_rate": 16000,
  "max_canonical_positions": 1024,
  "pitch_input_dim": 2,
  "pitch_encoder_hidden_size": null,
  "pitch_dropout": null,
  "pitch_frame_shift_ms": 20.0,
  "pitch_freq_low": 50.0,
  "pitch_freq_high": 400.0,
  "pitch_nccf_smoothing_frames": 5,
  "muon_learning_rate": 0.002,
  "muon_momentum": 0.95,
  "muon_weight_decay": 0.01,
  "adam_learning_rate": 0.0003,
  "adam_betas": [0.9, 0.98],
  "adam_eps": 1e-10,
  "adam_weight_decay": 0.01,
  "num_train_epochs": 50,
  "per_device_train_batch_size": 12,
  "per_device_eval_batch_size": 12,
  "gradient_accumulation_steps": 2,
  "warmup_steps": 1000,
  "logging_steps": 50,
  "eval_steps": 200,
  "save_steps": 200,
  "save_total_limit": 3,
  "dataloader_num_workers": 2,
  "fp16": "auto",
  "freeze_feature_encoder": false,
  "freeze_wav2vec2": true,
  "speed_perturb_prob": 0.3,
  "speed_perturb_range": [0.9, 1.1],
  "speed_perturb_bins": 5,
  "pitch_perturb_prob": 0.1,
  "pitch_perturb_range": [-0.2, 0.2],
  "pitch_perturb_bins": 5,
  "pitch_perturb_n_fft": 512,
  "use_weighted_sampler": true,
  "normal_sample_weight": 1.0,
  "error_sample_weight": 2.0,
  "apply_spec_augment": true,
  "mask_time_prob": 0.025,
  "mask_time_length": 10,
  "mask_feature_prob": 0.001,
  "mask_feature_length": 16,
  "report_to": "none",
  "resume_from_checkpoint": null
}
